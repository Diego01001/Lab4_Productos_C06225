@model DirectorioDeProductos.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1>Eliminar Producto</h1>

<div class="alert alert-warning">
    ¿Está seguro de que desea eliminar este producto?
</div>

<div class="card mb-3">
    <div class="card-body">
        <p><strong>Id:</strong> @Model.Id</p>
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Precio:</strong> @Model.Precio.ToString("$0.00")</p>
        <p><strong>Categoría:</strong> @Model.Categoria</p>
    </div>
</div>

<form asp-controller="Productos" asp-action="EliminarConfirmado" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Confirmar eliminación</button>
    <a asp-controller="Productos" asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>